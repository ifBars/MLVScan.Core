{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "files": [
            "MLVScan.Core.csproj"
          ]
        }
      ],
      "dest": "api",
      "namespaceLayout": "Nested",
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "shouldSkipMarkup": false,
      "properties": {
        "TargetFramework": "netstandard2.1"
      },
      "force": true,
      "repo": {
        "remote": "https://github.com/ifBars/MLVScan.Core.git",
        "branch": "main",
        "path": "."
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "index.md",
          "toc.yml",
          "README.md",
          "ENVIRONMENT_GUIDANCE.md",
          "ENVIRONMENT_API_REFERENCE.md",
          "CODING_STANDARDS.md",
          "api/**.yml"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern",
      "templates/material"
    ],
    "globalMetadata": {
      "_appName": "MLVScan.Core",
      "_appTitle": "MLVScan.Core Documentation",
      "_enableSearch": true,
      "_navbarTitle": "MLVScan.Core",
      "pdf": true
    }
  }
}
